{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://spatialanalyzer.github.io/briosa/catalog/schemas/v1/catalog.schema.json",
  "title": "Briosa exact-target command catalog manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_version",
    "catalog_id",
    "catalog_revision",
    "spatial_analyzer_target",
    "target_protocol_package",
    "sources",
    "operation_files"
  ],
  "properties": {
    "$schema": {
      "const": "../../schemas/v1/catalog.schema.json"
    },
    "schema_version": {
      "const": 1
    },
    "catalog_id": {
      "type": "string",
      "pattern": "^briosa\\.sa\\.[0-9]+(?:\\.[0-9]+)+$"
    },
    "catalog_revision": {
      "type": "string",
      "pattern": "^[1-9][0-9]*$"
    },
    "spatial_analyzer_target": {
      "type": "string",
      "pattern": "^[0-9]+(?:\\.[0-9]+)+$"
    },
    "target_protocol_package": {
      "type": "string",
      "pattern": "^briosa\\.sa\\.v[0-9]+(?:_[0-9]+)+\\.v[0-9]+(?:alpha|beta)?[0-9]+$"
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source_id",
          "kind",
          "description",
          "source_material_committed"
        ],
        "properties": {
          "source_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "kind": {
            "enum": [
              "installed_mp_documentation",
              "generated_sdk_sample",
              "maintainer_review"
            ]
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "source_material_committed": {
            "type": "boolean"
          }
        }
      }
    },
    "operation_files": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^operations/[a-z][a-z0-9_]*\\.[a-z][a-z0-9_]*\\.json$"
      }
    }
  }
}
